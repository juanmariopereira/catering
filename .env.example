# ==============================================================================
# Plantilla de variables de entorno
# ------------------------------------------------------------------------------
# Copia este archivo a `.env` (desarrollo) o `.env.production` (producción) y
# rellena los valores. NUNCA subas tus archivos `.env` reales al control de
# versiones: contienen secretos. Aquí solo van valores de ejemplo.
#
# El sistema es genérico: personaliza la marca, idioma y zona horaria desde
# aquí para usarlo con cualquier empresa de catering, sin tocar código.
# ==============================================================================


# ------------------------------------------------------------------------------
# Marca de la empresa (personalización por catering)
# ------------------------------------------------------------------------------
# Nombre que se muestra en la cabecera, títulos y mensajes de IA.
CATERING_NAME=Mi Catering

# Color principal de marca y su variante para hover (formato hex).
# A partir de estos, la interfaz deriva automáticamente los tonos claros/oscuros.
BRAND_COLOR=#7CB342
BRAND_COLOR_HOVER=#689F38

# Paleta para las gráficas (series por plan, etc.). Colores separados por comas.
# La primera entrada debería ser tu color de marca. Si se deja vacío, se usa una
# paleta por defecto que ya empieza por BRAND_COLOR.
CHART_PALETTE=#7CB342,#1565c0,#ff9800,#9c27b0,#00acc1,#5d4037,#e91e63,#673ab7,#00bcd4
# Color para las líneas de totales/agregados en las gráficas.
CHART_TOTAL_COLOR=#37474f


# ------------------------------------------------------------------------------
# Localización
# ------------------------------------------------------------------------------
# Código de idioma (ej. es, es-mx, es-es, en).
LANGUAGE_CODE=es
# Zona horaria (ej. America/Mexico_City, America/Bogota, Europe/Madrid).
TIME_ZONE=America/Mexico_City


# ------------------------------------------------------------------------------
# Integraciones externas
# ------------------------------------------------------------------------------
# OpenAI: habilita las funciones de IA (mensajes, menús, recetas). Opcional.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Maps: geocodificación y rutas. Opcional.
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Clave restringida para uso en el navegador. Si se omite, se reutiliza la anterior.
GOOGLE_MAPS_BROWSER_API_KEY=

# WhatsApp Cloud API (Meta). Opcional, para envío de mensajes a clientes.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=


# ------------------------------------------------------------------------------
# Django / Producción
# (requeridas al usar base.settings.production con DEBUG=False)
# ------------------------------------------------------------------------------
# Entorno lógico para Sentry y logs.
DJANGO_ENV=production

# False en producción, True en desarrollo local.
DEBUG=False

# Clave secreta de Django. OBLIGATORIA en producción. Genera una única y aleatoria.
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Dominios permitidos, separados por comas. OBLIGATORIO en producción.
ALLOWED_HOSTS=midominio.com,www.midominio.com

# Orígenes de confianza para CSRF (incluye el esquema). Separados por comas.
CSRF_TRUSTED_ORIGINS=https://midominio.com,https://www.midominio.com

# Redirigir todo el tráfico a HTTPS (True por defecto en producción).
SECURE_SSL_REDIRECT=True


# ------------------------------------------------------------------------------
# Base de datos (producción)
# ------------------------------------------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=catering
DB_USER=catering_user
DB_PASSWORD=cambia-esta-contrasena
DB_HOST=localhost
DB_PORT=5432


# ------------------------------------------------------------------------------
# Sentry (monitoreo de errores). Opcional: si SENTRY_DSN está vacío, se desactiva.
# ------------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
